<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros" />
  <PropertyGroup />
  <PropertyGroup Label="LLVMDir">
    <LLVMInstallDir>D:/llvm</LLVMInstallDir>
    <LLVMToolsVersion>22</LLVMToolsVersion>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalOptions>
 /clang:-fwrapv
 /clang:-fno-strict-aliasing
 /clang:-foptimize-sibling-calls
 /clang:-mllvm
 /clang:-trap-unreachable
 /clang:-Wall
 /clang:-Wextra
 /clang:-Winfinite-recursion
 /clang:-Wno-macro-redefined
 /clang:-Wno-deprecated-volatile
 /clang:-Wno-tautological-constant-out-of-range-compare
 /clang:-Wno-c99-designator
 /clang:-Wno-logical-op-parentheses
 /clang:-Wno-unused
 /clang:-Wno-unused-parameter
 /clang:-Wno-deprecated-declarations
 /clang:-Wno-unused-command-line-argument
 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemGroup />
</Project>